# WebPayback Protocol Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/webpayback

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here-should-be-at-least-32-characters
SESSION_SECRET=your-session-secret-here-should-be-at-least-32-characters

# Server Configuration
NODE_ENV=development
PORT=5000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://webpayback.replit.app

# Gas Pool Configuration
MIN_POOL_BALANCE=1.0
CRITICAL_POOL_BALANCE=0.1
EMERGENCY_POOL_BALANCE=0.01

# AI Monitoring Configuration
AI_CONFIDENCE_THRESHOLD=0.3
KNOWLEDGE_TRACKING_ENABLED=true

# Blockchain Configuration
POLYGON_RPC_URL=https://polygon-rpc.com
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR-PROJECT-ID
BSC_RPC_URL=https://bsc-dataseed.binance.org/
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# WPT Token Configuration
WPT_TOKEN_ADDRESS=0x9077051D318b614F915E8A0786506e4c0b7b4c5c
WPT_TOKEN_DECIMALS=18

# Chainlink Configuration - VRF V2 for Polygon
CHAINLINK_VRF_COORDINATOR=0xAE975071Be8F8eE67addBC1A82488F1C24858067
CHAINLINK_VRF_KEY_HASH=0x6e099d640cde6de9d40ac749b4b594126b0169747122711109c9985d47751f93
CHAINLINK_VRF_SUBSCRIPTION_ID=your-vrf-subscription-id

# Chainlink Functions Configuration
CHAINLINK_FUNCTIONS_SUBSCRIPTION_ID=your-functions-subscription-id

# External Services
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR-WEBHOOK-ID/YOUR-WEBHOOK-TOKEN
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Monitoring Configuration
SENTRY_DSN=https://your-sentry-dsn
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900000

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AWS Configuration (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=webpayback-assets

# Analytics Configuration (Optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
MIXPANEL_TOKEN=your-mixpanel-token

# Development Configuration
DEBUG=webpayback:*
ENABLE_SWAGGER=true
ENABLE_PLAYGROUND=true

# Blockchain Secrets (Configure these for your deployment)
ALCHEMY_API_KEY=your_alchemy_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here  
PRIVATE_KEY=your_wallet_private_key_here
FOUNDER_WALLET=your_founder_wallet_address_here
QLOO_API_KEY=your_qloo_api_key_here

# Humanity Protocol Configuration
HUMANITY_API_URL=https://api.humanity.org
HUMANITY_RPC_URL=https://rpc.humanity.org
HUMANITY_CLIENT_ID=app_********************************
HUMANITY_CLIENT_SECRET=sk_****************************************************************
HUMANITY_REDIRECT_URI=http://localhost:5000/api/humanity/callback
WPT_HUMAN_ADDRESS=0x0000000000000000000000000000000000000000
MOCK_HUMANITY=false

# Privy Wallet Abstraction
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Paymaster Configuration (Pimlico)
VITE_PIMLICO_API_KEY=your_pimlico_api_key_here
