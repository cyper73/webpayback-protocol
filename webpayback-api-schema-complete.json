  "components": {
    "securitySchemes": {
      "csrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CSRF-Token"
      },
      "sessionAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Session-ID"
      }
    },
    "schemas": {
      "Creator": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "userId": {"type": "integer"},
          "websiteUrl": {"type": "string"},
          "walletAddress": {"type": "string"},
          "verificationStatus": {"type": "string"},
          "reputationScore": {"type": "number"},
          "channelType": {"type": "string"},
          "isVerified": {"type": "boolean"},
          "createdAt": {"type": "string"}
        }
      },
      "Reward": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "creatorId": {"type": "integer"},
          "amount": {"type": "string"},
          "type": {"type": "string"},
          "status": {"type": "string"},
          "createdAt": {"type": "string"}
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "type": {"type": "string"},
          "status": {"type": "string"},
          "accuracy": {"type": "number"},
          "uptime": {"type": "number"},
          "tasksCompleted": {"type": "integer"}
        }
      },
      "PoolInfo": {
        "type": "object",
        "properties": {
          "poolAddress": {"type": "string"},
          "token0": {"type": "string"},
          "token1": {"type": "string"},
          "fee": {"type": "integer"},
          "liquidity": {"type": "string"},
          "sqrtPriceX96": {"type": "string"}
        }
      },
      "SecurityEvent": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "type": {"type": "string"},
          "severity": {"type": "string"},
          "description": {"type": "string"},
          "timestamp": {"type": "string"},
          "resolved": {"type": "boolean"}
        }
      }
    }
